<!doctype html>
<html lang="es">
<head>
  <%- include('../partials/head') %>
</head>
<body>
  <%- include('../partials/nav') %>
  <div class="container">
    <h2 class="mb-4">Panel administrativo</h2>
    <div id="alerta-error" class="alert alert-danger d-none"></div>

    <div class="row g-3 mb-4" id="stats-cards"></div>

    <ul class="nav nav-tabs mb-4">
      <li class="nav-item"><button class="nav-link active" data-bs-toggle="tab" data-bs-target="#tab-validaciones">Validaciones pendientes</button></li>
      <li class="nav-item"><button class="nav-link" data-bs-toggle="tab" data-bs-target="#tab-comites">Comités</button></li>
      <li class="nav-item"><button class="nav-link" data-bs-toggle="tab" data-bs-target="#tab-exportar">Exportar</button></li>
    </ul>

    <div class="tab-content">
      <div class="tab-pane fade show active" id="tab-validaciones">
        <div id="lista-validaciones" class="row g-3"></div>
      </div>

      <div class="tab-pane fade" id="tab-comites">
        <div class="row g-3" id="lista-comites-admin"></div>
      </div>

      <div class="tab-pane fade" id="tab-exportar">
        <div class="card p-4">
          <a href="/admin/exportar/militantes" class="btn btn-outline-primary me-2">Exportar militantes (CSV)</a>
          <a href="/admin/exportar/comites" class="btn btn-outline-primary">Exportar comités (CSV)</a>
        </div>
      </div>
    </div>
  </div>

  <!-- Modal fotos validacion -->
  <div class="modal fade" id="modalFotos" tabindex="-1">
    <div class="modal-dialog modal-lg">
      <div class="modal-content">
        <div class="modal-header">
          <h5 class="modal-title">Fotos de validación</h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
        </div>
        <div class="modal-body row g-3" id="modal-fotos-body"></div>
      </div>
    </div>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  <script src="/public/js/api.js"></script>
  <script src="/public/js/nav.js"></script>
  <script src="/public/js/admin-panel.js"></script>
</body>
</html>
