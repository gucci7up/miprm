<!doctype html>
<html lang="es">
<head>
  <%- include('../partials/head') %>
</head>
<body>
  <%- include('../partials/nav') %>
  <div class="container">
    <div class="row justify-content-center">
      <div class="col-lg-7">
        <div class="card p-4 p-md-5">
          <h2 class="mb-1">Validación de identidad</h2>
          <p class="text-muted mb-4">Sube fotos de tu cédula y una selfie para validar tu cuenta.</p>

          <div id="alerta-error" class="alert alert-danger d-none"></div>
          <div id="estado-actual" class="alert d-none"></div>

          <form id="form-validacion" class="d-none">
            <div class="row g-3 mb-3">
              <div class="col-md-4">
                <label class="form-label">Cédula — frente</label>
                <input type="file" class="form-control" name="cedulaFrente" accept="image/*" required />
                <img class="foto-preview mt-2" id="preview-frente" />
              </div>
              <div class="col-md-4">
                <label class="form-label">Cédula — dorso</label>
                <input type="file" class="form-control" name="cedulaDorso" accept="image/*" required />
                <img class="foto-preview mt-2" id="preview-dorso" />
              </div>
              <div class="col-md-4">
                <label class="form-label">Selfie</label>
                <input type="file" class="form-control" name="selfie" accept="image/*" required />
                <img class="foto-preview mt-2" id="preview-selfie" />
              </div>
            </div>
            <button type="submit" class="btn btn-primary" id="btn-submit">Enviar validación</button>
          </form>
        </div>
      </div>
    </div>
  </div>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  <script src="/public/js/api.js"></script>
  <script src="/public/js/nav.js"></script>
  <script src="/public/js/validacion.js"></script>
</body>
</html>
