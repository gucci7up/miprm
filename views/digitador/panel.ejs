<!doctype html>
<html lang="es">
<head>
  <%- include('../partials/head') %>
</head>
<body>
  <%- include('../partials/nav') %>
  <div class="container">
    <h2 class="mb-4">Panel de digitador</h2>
    <div id="alerta-error" class="alert alert-danger d-none"></div>
    <div id="alerta-exito" class="alert alert-success d-none"></div>

    <ul class="nav nav-tabs mb-4">
      <li class="nav-item"><button class="nav-link active" data-bs-toggle="tab" data-bs-target="#tab-registrar">Registrar militante</button></li>
      <li class="nav-item"><button class="nav-link" data-bs-toggle="tab" data-bs-target="#tab-crear-comite">Crear comité</button></li>
    </ul>

    <div class="tab-content">
      <!-- REGISTRAR MILITANTE -->
      <div class="tab-pane fade show active" id="tab-registrar">
        <div class="card p-4 p-md-5">
          <p class="text-muted">Transcribe los datos del formulario físico. Se le enviará la contraseña de acceso por SMS o correo.</p>
          <form id="form-registrar">
            <div class="row g-3 mb-3">
              <div class="col-md-4">
                <label class="form-label">Cédula *</label>
                <div class="input-group">
                  <input type="text" class="form-control" name="cedula" id="reg-cedula" maxlength="11" required />
                  <button type="button" class="btn btn-outline-secondary" id="btn-buscar-padron">Buscar en padrón</button>
                </div>
              </div>
              <div class="col-md-4">
                <label class="form-label">Nombres *</label>
                <input type="text" class="form-control" name="nombres" id="reg-nombres" required />
              </div>
              <div class="col-md-4">
                <label class="form-label">Apellidos *</label>
                <input type="text" class="form-control" name="apellidos" id="reg-apellidos" required />
              </div>

              <div class="col-md-4">
                <label class="form-label">Fecha de nacimiento</label>
                <input type="date" class="form-control" name="fechaNacimiento" id="reg-fechaNacimiento" />
              </div>
              <div class="col-md-4">
                <label class="form-label">Teléfono *</label>
                <input type="text" class="form-control" name="telefono" required />
              </div>
              <div class="col-md-4">
                <label class="form-label">WhatsApp</label>
                <input type="text" class="form-control" name="whatsapp" />
              </div>

              <div class="col-md-6">
                <label class="form-label">Correo (opcional)</label>
                <input type="email" class="form-control" name="email" />
              </div>
              <div class="col-md-6">
                <label class="form-label">Alias (opcional)</label>
                <input type="text" class="form-control" name="alias" />
              </div>

              <div class="col-12"><hr /></div>

              <div class="col-md-6">
                <label class="form-label">Calle</label>
                <input type="text" class="form-control" name="calle" />
              </div>
              <div class="col-md-3">
                <label class="form-label">Número de casa</label>
                <input type="text" class="form-control" name="numeroCasa" />
              </div>
              <div class="col-md-3">
                <label class="form-label">Sector / barrio</label>
                <input type="text" class="form-control" name="sector" />
              </div>

              <div class="col-md-6">
                <label class="form-label">Contacto secundario — nombre</label>
                <input type="text" class="form-control" name="contactoNombre" />
              </div>
              <div class="col-md-6">
                <label class="form-label">Contacto secundario — teléfono</label>
                <input type="text" class="form-control" name="contactoTelefono" />
              </div>
            </div>
            <button type="submit" class="btn btn-primary" id="btn-submit-registrar">Registrar militante</button>
          </form>
        </div>
      </div>

      <!-- CREAR COMITE -->
      <div class="tab-pane fade" id="tab-crear-comite">
        <div class="card p-4 p-md-5">
          <form id="form-crear-comite">
            <div class="mb-3">
              <label class="form-label">Nombre del comité *</label>
              <input type="text" class="form-control" name="nombre" required />
            </div>
            <div class="row g-3 mb-3">
              <div class="col-md-6">
                <label class="form-label">Provincia *</label>
                <select class="form-select" id="select-provincia" required>
                  <option value="">Selecciona...</option>
                </select>
              </div>
              <div class="col-md-6">
                <label class="form-label">Municipio *</label>
                <select class="form-select" id="select-municipio" required disabled>
                  <option value="">Primero selecciona provincia</option>
                </select>
              </div>
            </div>
            <div class="mb-3">
              <label class="form-label">Zona (opcional)</label>
              <select class="form-select" id="select-zona">
                <option value="">Sin especificar</option>
              </select>
            </div>
            <div class="alert alert-info small mb-3">
              Después de crear el comité podrás asignar un coordinador desde "Editar comité".
            </div>
            <div class="mb-4">
              <label class="form-label">Logo (opcional)</label>
              <input type="file" class="form-control" name="logo" accept="image/*" />
            </div>
            <button type="submit" class="btn btn-primary" id="btn-submit-comite">Crear comité</button>
          </form>
        </div>
      </div>
    </div>
  </div>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  <script src="/public/js/api.js"></script>
  <script src="/public/js/nav.js"></script>
  <script src="/public/js/digitador-panel.js"></script>
</body>
</html>
