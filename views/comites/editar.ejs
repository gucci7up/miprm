<!doctype html>
<html lang="es">
<head>
  <%- include('../partials/head') %>
</head>
<body>
  <%- include('../partials/nav') %>
  <div class="container" data-comite-id="<%= comiteId %>">
    <div id="alerta-error" class="alert alert-danger d-none"></div>

    <div class="d-flex justify-content-between align-items-center mb-3">
      <h2 class="mb-0" id="titulo-comite">Cargando...</h2>
      <div class="d-flex align-items-center gap-2">
        <span class="badge" id="badge-activo"></span>
        <button class="btn btn-outline-secondary btn-sm" id="btn-imprimir"><i class="bi bi-printer"></i> Imprimir</button>
      </div>
    </div>

    <div class="mb-3 d-flex align-items-center gap-2">
      <span class="text-muted small">Coordinador:</span>
      <strong id="coordinador-nombre">Sin asignar</strong>
      <button class="btn btn-sm btn-outline-primary d-none" id="btn-cambiar-coordinador" data-bs-toggle="modal" data-bs-target="#modalCoordinador">
        Asignar / cambiar
      </button>
    </div>

    <ul class="nav nav-tabs mb-4" role="tablist">
      <li class="nav-item"><button class="nav-link active" data-bs-toggle="tab" data-bs-target="#tab-general">Información general</button></li>
      <li class="nav-item"><button class="nav-link" data-bs-toggle="tab" data-bs-target="#tab-actividades">Actividades</button></li>
      <li class="nav-item"><button class="nav-link" data-bs-toggle="tab" data-bs-target="#tab-miembros">Miembros</button></li>
    </ul>

    <div class="tab-content">
      <!-- INFO GENERAL -->
      <div class="tab-pane fade show active" id="tab-general">
        <div class="card p-4">
          <form id="form-info-general">
            <div class="mb-3">
              <label class="form-label">Nombre</label>
              <input type="text" class="form-control" name="nombre" id="input-nombre" />
            </div>
            <div class="row g-3 mb-3">
              <div class="col-md-4">
                <label class="form-label">Provincia</label>
                <select class="form-select" id="select-provincia"></select>
              </div>
              <div class="col-md-4">
                <label class="form-label">Municipio</label>
                <select class="form-select" id="select-municipio"></select>
              </div>
              <div class="col-md-4">
                <label class="form-label">Zona</label>
                <select class="form-select" id="select-zona"></select>
              </div>
            </div>
            <div class="mb-3">
              <label class="form-label">Logo</label>
              <div class="mb-2"><img id="logo-actual" class="foto-preview d-none" /></div>
              <input type="file" class="form-control" name="logo" accept="image/*" />
            </div>
            <div class="form-check form-switch mb-3">
              <input class="form-check-input" type="checkbox" id="input-activo" />
              <label class="form-check-label" for="input-activo">Comité activo</label>
            </div>
            <button type="submit" class="btn btn-primary" id="btn-guardar-general">Guardar cambios</button>
          </form>
        </div>
      </div>

      <!-- ACTIVIDADES -->
      <div class="tab-pane fade" id="tab-actividades">
        <div id="form-actividad-wrap" class="card p-4 mb-4 d-none">
          <h6 class="mb-3">Nueva actividad</h6>
          <form id="form-actividad">
            <div class="mb-3">
              <label class="form-label">Nombre</label>
              <input type="text" class="form-control" name="nombre" required />
            </div>
            <div class="mb-3">
              <label class="form-label">Descripción</label>
              <textarea class="form-control" name="descripcion" rows="2"></textarea>
            </div>
            <div class="row g-3 mb-3">
              <div class="col-md-6">
                <label class="form-label">Fecha inicio</label>
                <input type="date" class="form-control" name="fechaInicio" required />
              </div>
              <div class="col-md-6">
                <label class="form-label">Fecha fin</label>
                <input type="date" class="form-control" name="fechaFin" required />
              </div>
            </div>
            <div class="mb-3">
              <label class="form-label">Imagen (opcional)</label>
              <input type="file" class="form-control" name="imagen" accept="image/*" />
            </div>
            <button type="submit" class="btn btn-primary btn-sm">Agregar actividad</button>
          </form>
        </div>
        <div id="lista-actividades" class="row g-3"></div>
      </div>

      <!-- MIEMBROS -->
      <div class="tab-pane fade" id="tab-miembros">
        <div id="form-miembro-wrap" class="card p-4 mb-4 d-none">
          <h6 class="mb-3">Agregar miembro</h6>
          <form id="form-miembro" class="row g-3">
            <div class="col-md-4">
              <label class="form-label">Cédula</label>
              <input type="text" class="form-control" name="cedula" maxlength="11" required />
            </div>
            <div class="col-md-4">
              <label class="form-label">Fecha de nacimiento</label>
              <input type="date" class="form-control" name="fechaNacimiento" required />
            </div>
            <div class="col-md-3">
              <label class="form-label">Rol</label>
              <select class="form-select" name="rol" required>
                <option value="ENLACE">Enlace</option>
                <option value="MIEMBRO">Miembro</option>
              </select>
            </div>
            <div class="col-md-1 d-flex align-items-end">
              <button type="submit" class="btn btn-primary w-100">+</button>
            </div>
          </form>
        </div>
        <table class="table bg-white">
          <thead><tr><th>Nombre</th><th>Cédula</th><th>Rol</th><th></th></tr></thead>
          <tbody id="tabla-miembros"></tbody>
        </table>
      </div>
    </div>

    <!-- Seccion imprimible (oculta, se usa solo al imprimir) -->
    <div class="d-none" id="seccion-imprimir">
      <style>
        .print-header { text-align:center; margin-bottom:16px; }
        .print-info { display:flex; justify-content:space-between; flex-wrap:wrap; gap:8px 24px; border:1px solid #ccc; border-radius:8px; padding:10px 16px; margin-bottom:16px; font-size:12px; }
        .print-info div { min-width:140px; }
        .print-grid { display:grid; grid-template-columns:1fr 1fr; gap:10px; }
        .print-card { border:1px solid #999; border-radius:6px; overflow:hidden; }
        .print-card-rol { background:#eee; font-size:10px; font-weight:700; text-transform:uppercase; padding:3px 8px; }
        .print-card-body { display:flex; gap:8px; padding:8px; }
        .print-card-foto { width:56px; height:56px; object-fit:cover; border-radius:4px; background:#ddd; flex-shrink:0; }
        .print-card-cedula { font-size:11px; color:#555; }
        .print-card-nombre { font-size:12px; font-weight:700; }
        .print-card-detalle { font-size:10px; color:#555; }
      </style>
      <div class="print-header">
        <h2 style="margin:0;font-size:16px;">MIPRM</h2>
        <h3 style="font-size:12px;font-weight:normal;margin:2px 0;">Comité Afectivo</h3>
      </div>
      <div class="print-info">
        <div><strong>Comité:</strong> <span id="print-nombre"></span></div>
        <div><strong>Provincia:</strong> <span id="print-provincia"></span></div>
        <div><strong>Municipio / DM:</strong> <span id="print-municipio"></span></div>
        <div><strong>Zona:</strong> <span id="print-zona"></span></div>
        <div><strong>Fecha:</strong> <span id="print-fecha"></span></div>
      </div>
      <div class="print-grid" id="print-miembros"></div>
    </div>
  </div>

  <!-- Modal asignar/cambiar coordinador -->
  <div class="modal fade" id="modalCoordinador" tabindex="-1">
    <div class="modal-dialog">
      <div class="modal-content">
        <div class="modal-header">
          <h5 class="modal-title">Asignar / cambiar coordinador</h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
        </div>
        <form id="form-coordinador">
          <div class="modal-body">
            <div class="mb-3">
              <label class="form-label">Cédula</label>
              <input type="text" class="form-control" name="cedula" maxlength="11" required />
            </div>
            <div class="mb-3">
              <label class="form-label">Fecha de nacimiento</label>
              <input type="date" class="form-control" name="fechaNacimiento" required />
            </div>
            <div class="form-text">Debe ser un militante ya registrado.</div>
          </div>
          <div class="modal-footer">
            <button type="submit" class="btn btn-primary">Guardar</button>
          </div>
        </form>
      </div>
    </div>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  <script src="/public/js/api.js"></script>
  <script src="/public/js/nav.js"></script>
  <script src="/public/js/comite-editar.js"></script>
</body>
</html>
