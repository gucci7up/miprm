# === Base de datos principal (PostgreSQL) — tablas propias de MIPRM, gestionada por Prisma ===
DATABASE_URL="postgresql://usuario:clave@localhost:5432/miprm?schema=public"

# === SQL Server externo (SOLO LECTURA) — padron/personas y division territorial ===
# No se gestiona con Prisma: se consulta con el paquete 'mssql' via queries cruzadas entre bases.
SQLSERVER_HOST=changeme
SQLSERVER_PORT=1433
SQLSERVER_USER=changeme
SQLSERVER_PASSWORD=changeme
SQLSERVER_DB_PADRON=changeme
SQLSERVER_DB_PRM=changeme
SQLSERVER_ENCRYPT=false
SQLSERVER_TRUST_SERVER_CERTIFICATE=true

# === Servidor ===
PORT=3000
NODE_ENV=development
APP_BASE_URL=http://localhost:3000

# === Autenticacion ===
JWT_SECRET=changeme_generate_a_long_random_string
SESSION_SECRET=changeme_generate_another_long_random_string
JWT_EXPIRES_IN=7d

# === Almacenamiento de archivos ===
# Las fotos (logo de comite, imagen de actividad, cedula/selfie de validacion)
# se guardan como BLOB dentro de Postgres, no en disco.
MAX_UPLOAD_MB=5

# === Correo (nodemailer) ===
# Si se dejan vacias, el servicio de notificaciones cae a modo "log a consola"
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM="MIPRM <no-reply@miprm.org>"

# === SMS (Twilio) ===
# Si se dejan vacias, el servicio de notificaciones cae a modo "log a consola"
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# === Rate limiting login ===
LOGIN_RATE_WINDOW_MIN=15
LOGIN_RATE_MAX_ATTEMPTS=10
